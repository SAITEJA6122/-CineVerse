# Copy to frontend/.env for local dev. In production (Netlify), set
# REACT_APP_API_URL in Site settings -> Environment variables, then redeploy.
# It must point at your deployed backend and include the trailing /api.
# Example: REACT_APP_API_URL=https://cineverse-backend.onrender.com/api
REACT_APP_API_URL=http://localhost:5000/api
