# Copy to backend/.env for local dev, or set these in your host (Render) dashboard.
PORT=5000
# MongoDB Atlas connection string (required — the backend needs a database).
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/movieticketbooking?retryWrites=true&w=majority
JWT_SECRET=replace-with-a-long-random-secret
NODE_ENV=development
